{
  "name": "gmail-calendar",
  "version": "1.0.1",
  "description": "Google Calendar integration displaying upcoming events",
  "minAppVersion": "0.1.0",
  "type": [
    "connector",
    "visualization"
  ],
  "oauth": {
    "provider": "google",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  },
  "visualizations": [
    {
      "name": "Calendar",
      "description": "7-day calendar with five layout variants",
      "path": "calendar",
      "properties": [
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "Widget title shown in the editor"
        },
        {
          "name": "layout",
          "type": "choice",
          "required": false,
          "default": "xl",
          "choices": [
            {
              "label": "XL — 7-day full",
              "value": "xl"
            },
            {
              "label": "L — 7-day compact",
              "value": "l"
            },
            {
              "label": "M — 3-day",
              "value": "m"
            },
            {
              "label": "S — Today only",
              "value": "s"
            },
            {
              "label": "Vertical — 7-day rows",
              "value": "vertical"
            }
          ],
          "description": "Layout variant"
        }
      ],
      "mockData": {
